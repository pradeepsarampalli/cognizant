<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:context="http://www.springframework.org/schema/context"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
                            http://www.springframework.org/schema/beans/spring-beans.xsd
                            http://www.springframework.org/schema/context
                            http://www.springframework.org/schema/context/spring-context.xsd">

    <!--
        Exercise 6: Enable component scanning for the com.library package
        so classes annotated with @Service, @Repository, @Component (and
        @Aspect via LoggingAspect) are auto-detected and registered as
        beans, with dependencies auto-wired via the @Autowired constructor
        in BookService.
    -->

    <context:component-scan base-package="com.library"/>
    <context:annotation-config/>

</beans>
