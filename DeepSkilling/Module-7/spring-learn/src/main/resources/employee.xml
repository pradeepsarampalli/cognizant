<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Used to parse dd/MM/yyyy date-of-birth strings below into java.util.Date -->
    <bean id="employeeDateFormat" class="java.text.SimpleDateFormat">
        <constructor-arg value="dd/MM/yyyy" />
    </bean>

    <!-- Departments -->
    <bean id="engineering" class="com.cognizant.springlearn.model.Department">
        <property name="id" value="1" />
        <property name="name" value="Engineering" />
    </bean>

    <bean id="finance" class="com.cognizant.springlearn.model.Department">
        <property name="id" value="2" />
        <property name="name" value="Finance" />
    </bean>

    <bean id="departmentList" class="java.util.ArrayList">
        <constructor-arg>
            <list>
                <ref bean="engineering" />
                <ref bean="finance" />
            </list>
        </constructor-arg>
    </bean>

    <!-- Skills (reused across employees) -->
    <bean id="java" class="com.cognizant.springlearn.model.Skill">
        <property name="id" value="1" />
        <property name="name" value="Java" />
    </bean>

    <bean id="spring" class="com.cognizant.springlearn.model.Skill">
        <property name="id" value="2" />
        <property name="name" value="Spring Boot" />
    </bean>

    <bean id="angular" class="com.cognizant.springlearn.model.Skill">
        <property name="id" value="3" />
        <property name="name" value="Angular" />
    </bean>

    <bean id="excel" class="com.cognizant.springlearn.model.Skill">
        <property name="id" value="4" />
        <property name="name" value="Excel" />
    </bean>

    <!-- Employees -->
    <bean id="employee1" class="com.cognizant.springlearn.model.Employee">
        <property name="id" value="1" />
        <property name="name" value="John Smith" />
        <property name="salary" value="55000" />
        <property name="permanent" value="true" />
        <property name="dateOfBirth">
            <bean factory-bean="employeeDateFormat" factory-method="parse">
                <constructor-arg value="14/05/1990" />
            </bean>
        </property>
        <property name="department" ref="engineering" />
        <property name="skills">
            <list>
                <ref bean="java" />
                <ref bean="spring" />
            </list>
        </property>
    </bean>

    <bean id="employee2" class="com.cognizant.springlearn.model.Employee">
        <property name="id" value="2" />
        <property name="name" value="Priya Nair" />
        <property name="salary" value="62000" />
        <property name="permanent" value="true" />
        <property name="dateOfBirth">
            <bean factory-bean="employeeDateFormat" factory-method="parse">
                <constructor-arg value="02/11/1988" />
            </bean>
        </property>
        <property name="department" ref="engineering" />
        <property name="skills">
            <list>
                <ref bean="java" />
                <ref bean="angular" />
            </list>
        </property>
    </bean>

    <bean id="employee3" class="com.cognizant.springlearn.model.Employee">
        <property name="id" value="3" />
        <property name="name" value="Michael Chen" />
        <property name="salary" value="48000" />
        <property name="permanent" value="false" />
        <property name="dateOfBirth">
            <bean factory-bean="employeeDateFormat" factory-method="parse">
                <constructor-arg value="20/02/1995" />
            </bean>
        </property>
        <property name="department" ref="finance" />
        <property name="skills">
            <list>
                <ref bean="excel" />
            </list>
        </property>
    </bean>

    <bean id="employee4" class="com.cognizant.springlearn.model.Employee">
        <property name="id" value="4" />
        <property name="name" value="Sara Ahmed" />
        <property name="salary" value="71000" />
        <property name="permanent" value="true" />
        <property name="dateOfBirth">
            <bean factory-bean="employeeDateFormat" factory-method="parse">
                <constructor-arg value="30/07/1985" />
            </bean>
        </property>
        <property name="department" ref="finance" />
        <property name="skills">
            <list>
                <ref bean="excel" />
                <ref bean="spring" />
            </list>
        </property>
    </bean>

    <bean id="employeeList" class="java.util.ArrayList">
        <constructor-arg>
            <list>
                <ref bean="employee1" />
                <ref bean="employee2" />
                <ref bean="employee3" />
                <ref bean="employee4" />
            </list>
        </constructor-arg>
    </bean>

</beans>
